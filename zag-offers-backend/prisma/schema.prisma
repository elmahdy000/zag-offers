generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  MERCHANT
  ADMIN
  STAFF
}

enum StoreStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum OfferStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  EXPIRED
  PAUSED
}

enum CouponStatus {
  GENERATED
  USED
  EXPIRED
}

model User {
  id       String  @id @default(uuid())
  phone    String? @unique
  email    String? @unique
  password String?
  name     String
  role     Role    @default(CUSTOMER)

  googleId   String? @unique
  facebookId String? @unique
  avatar     String?
  area       String? // منطقة السكن للترشيحات
  fcmToken   String?
  resetOtp       String?
  resetOtpExpiry DateTime?

  stores    Store[]
  coupons   Coupon[]
  reviews   Review[]
  favorites Favorite[]
  auditLogs AuditLog[] @relation("AdminLogs")
  notifications Notification[]
  points    Int        @default(0)
  
  adminConversations Conversation[] @relation("AdminConversations")
  participantConversations Conversation[] @relation("ParticipantConversations")
  messages Message[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  analyticsEvents AnalyticsEvent[]

  @@index([role])
}

model Category {
  id     String  @id @default(uuid())
  name   String  @unique
  stores Store[]
}

model Store {
  id         String      @id @default(uuid())
  name       String
  logo       String?
  coverImage String?
  address    String
  area       String? // e.g. El Qawmeya
  lat        Float?
  lng        Float?
  phone      String
  whatsapp   String?
  status     StoreStatus @default(PENDING)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  offers  Offer[]
  reviews Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  analyticsEvents AnalyticsEvent[]

  @@index([area])
  @@index([status])
  @@index([categoryId])
  @@index([ownerId])
}

model Offer {
  id          String      @id @default(uuid())
  title       String
  description String
  images      String[]
  discount    String // e.g. "20%" or "BOGO"
  originalPrice Float?
  terms       String?
  startDate   DateTime
  endDate     DateTime
  usageLimit  Int?
  status      OfferStatus @default(PENDING)
  isNotified  Boolean     @default(false)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  coupons   Coupon[]
  reviews   Review[]
  favorites Favorite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  analyticsEvents AnalyticsEvent[]

  @@index([status])
  @@index([storeId])
  @@index([createdAt])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  offerId   String
  offer     Offer    @relation(fields: [offerId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, offerId])
  @@index([userId])
  @@index([offerId])
}

model Coupon {
  id        String       @id @default(uuid())
  code      String       @unique
  expiresAt DateTime
  status    CouponStatus @default(GENERATED)

  offerId String
  offer   Offer  @relation(fields: [offerId], references: [id])

  customerId String
  customer   User   @relation(fields: [customerId], references: [id])

  redeemedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([status])
  @@index([customerId])
  @@index([offerId])
}

model Review {
  id      String  @id @default(uuid())
  rating  Int
  comment String?
  images  String[] // لدعم صور التقييم للمصداقية

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  offerId String?
  offer   Offer?  @relation(fields: [offerId], references: [id])

  customerId String
  customer   User   @relation(fields: [customerId], references: [id])

  createdAt DateTime @default(now())

  @@index([storeId])
  @@index([customerId])
  @@index([rating])
  @@index([createdAt])
}

model Conversation {
  id            String    @id @default(uuid())
  type          String    // 'ADMIN_CUSTOMER' | 'ADMIN_MERCHANT'
  
  adminId       String
  admin         User      @relation("AdminConversations", fields: [adminId], references: [id])
  
  participantId String
  participant   User      @relation("ParticipantConversations", fields: [participantId], references: [id])
  
  messages      Message[]
  
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([adminId])
  @@index([participantId])
  @@index([type])
}

model Message {
  id             String       @id @default(uuid())
  text           String
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String   // e.g. "APPROVE_STORE", "REJECT_OFFER", "SEND_BROADCAST"
  details   String?  // JSON or text details
  targetId  String?  // ID of the affected entity (Store, Offer, User)
  targetName String? // Human readable name of target
  
  adminId   String
  admin     User     @relation("AdminLogs", fields: [adminId], references: [id])
  
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  body      String
  imageUrl  String?
  type      String?  // e.g., 'NEW_OFFER', 'BROADCAST'
  data      String?  // JSON payload
  isRead    Boolean  @default(false)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([isRead])
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  offerId   String?
  offer     Offer?   @relation(fields: [offerId], references: [id])
  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id])
  eventType String   // e.g., 'OFFER_VIEW', 'OFFER_FAVORITE', 'COUPON_GENERATE'
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([offerId])
  @@index([eventType])
  @@index([createdAt])
}

